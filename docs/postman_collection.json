{
    "info": {
        "name": "Notification Service",
        "description": "Коллекция для тестирования микросервиса уведомлений.\n\nЗапуск: `docker compose up -d --build`, затем выполняйте запросы по порядку (Run collection или вручную сверху вниз). Запросы 1-3 сохраняют значения в переменные коллекции, которые используют запросы 4+.\n\nМагические получатели управляют поведением мок-провайдера:\n- `fail-*` — провайдер отклоняет → статус `failed` без ретраев;\n- `flaky-*` — временные ошибки шлюза, успех с 3-й попытки;\n- `undeliverable-*` — принято шлюзом, но отчёт о доставке отрицательный → `failed`;\n- любой другой — `sent` → `delivered`.\n\nКаждый запрос содержит тесты (вкладка Tests) с проверкой кода ответа.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8080/api/v1"
        },
        {
            "key": "batch_id",
            "value": ""
        },
        {
            "key": "provider_message_id",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "1. Транзакционная SMS-рассылка",
            "event": [
                {
                    "listen": "prerequest",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.collectionVariables.set('idem_sms', 'sms-' + Date.now());"
                        ]
                    }
                },
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('202 Accepted', () => pm.response.to.have.status(202));",
                            "const json = pm.response.json();",
                            "pm.test('duplicate=false', () => pm.expect(json.duplicate).to.eql(false));",
                            "pm.test('создано 2 уведомления', () => pm.expect(json.data.notifications_count).to.eql(2));",
                            "pm.collectionVariables.set('batch_id', json.data.id);"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Idempotency-Key", "value": "{{idem_sms}}" },
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Accept", "value": "application/json" }
                ],
                "url": "{{base_url}}/notifications",
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"channel\": \"sms\",\n    \"priority\": \"transactional\",\n    \"text\": \"Ваш код доступа: 4821\",\n    \"recipient_ids\": [\"42\", \"108\"]\n}"
                }
            }
        },
        {
            "name": "2. Повтор того же запроса (идемпотентность)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('200 OK', () => pm.response.to.have.status(200));",
                            "const json = pm.response.json();",
                            "pm.test('duplicate=true', () => pm.expect(json.duplicate).to.eql(true));",
                            "pm.test('тот же batch, что и в шаге 1', () => pm.expect(json.data.id).to.eql(pm.collectionVariables.get('batch_id')));"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Idempotency-Key", "value": "{{idem_sms}}" },
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Accept", "value": "application/json" }
                ],
                "url": "{{base_url}}/notifications",
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"channel\": \"sms\",\n    \"priority\": \"transactional\",\n    \"text\": \"Ваш код доступа: 4821\",\n    \"recipient_ids\": [\"42\", \"108\"]\n}"
                },
                "description": "Тот же Idempotency-Key, что и в шаге 1: вернётся 200 с duplicate=true, новая рассылка не создаётся."
            }
        },
        {
            "name": "3. Маркетинговая Email-рассылка (все исходы)",
            "event": [
                {
                    "listen": "prerequest",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.collectionVariables.set('idem_email', 'email-' + Date.now());"
                        ]
                    }
                },
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('202 Accepted', () => pm.response.to.have.status(202));",
                            "pm.test('priority=marketing', () => pm.expect(pm.response.json().data.priority).to.eql('marketing'));"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Idempotency-Key", "value": "{{idem_email}}" },
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Accept", "value": "application/json" }
                ],
                "url": "{{base_url}}/notifications",
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"channel\": \"email\",\n    \"priority\": \"marketing\",\n    \"text\": \"Скидка 20% только сегодня!\",\n    \"recipient_ids\": [\"42\", \"undeliverable-7\", \"fail-13\", \"flaky-99\"]\n}"
                },
                "description": "Демонстрирует все исходы: обычная доставка (42), отрицательный DLR (undeliverable-7), отказ провайдера (fail-13), успех после ретраев (flaky-99). Подождите ~10 секунд перед шагом 4, чтобы воркеры обработали очередь."
            }
        },
        {
            "name": "4. История уведомлений получателя",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('200 OK', () => pm.response.to.have.status(200));",
                            "const json = pm.response.json();",
                            "pm.test('есть данные и пагинация', () => { pm.expect(json.data).to.be.an('array'); pm.expect(json.meta).to.have.property('total'); });",
                            "const delivered = json.data.find(n => n.status === 'delivered' && n.provider_message_id);",
                            "if (delivered) { pm.collectionVariables.set('provider_message_id', delivered.provider_message_id); }"
                        ]
                    }
                }
            ],
            "request": {
                "method": "GET",
                "header": [
                    { "key": "Accept", "value": "application/json" }
                ],
                "url": {
                    "raw": "{{base_url}}/recipients/42/notifications?per_page=10",
                    "host": ["{{base_url}}"],
                    "path": ["recipients", "42", "notifications"],
                    "query": [
                        { "key": "per_page", "value": "10" },
                        { "key": "status", "value": "delivered", "disabled": true },
                        { "key": "channel", "value": "sms", "disabled": true }
                    ]
                },
                "description": "История получателя 42, новые первыми. Снимите disabled с query-параметров status/channel, чтобы проверить фильтры. Сохраняет provider_message_id доставленного уведомления в переменную для шага 5."
            }
        },
        {
            "name": "5. Webhook отчёта о доставке (идемпотентность DLR)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('200 OK', () => pm.response.to.have.status(200));",
                            "const json = pm.response.json();",
                            "pm.test('applied=false (уведомление уже доставлено мок-провайдером)', () => pm.expect(json.applied).to.eql(false));"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Accept", "value": "application/json" }
                ],
                "url": "{{base_url}}/webhooks/delivery",
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"provider_message_id\": \"{{provider_message_id}}\",\n    \"status\": \"delivered\"\n}"
                },
                "description": "Использует provider_message_id из шага 4. Мок-провайдер уже подтвердил доставку этого уведомления автоматически, поэтому повторный отчёт идемпотентен и возвращает applied=false (переход разрешён только из sent). Так демонстрируется защита от дублирующихся и запоздавших отчётов."
            }
        },
        {
            "name": "6. Валидация: без Idempotency-Key (422)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('422 Unprocessable', () => pm.response.to.have.status(422));",
                            "pm.test('ошибка на поле idempotency_key', () => pm.expect(pm.response.json().errors).to.have.property('idempotency_key'));"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Accept", "value": "application/json" }
                ],
                "url": "{{base_url}}/notifications",
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"channel\": \"sms\",\n    \"text\": \"Без ключа идемпотентности\",\n    \"recipient_ids\": [\"42\"]\n}"
                },
                "description": "Заголовок Idempotency-Key обязателен — ожидается 422 с ошибкой валидации."
            }
        },
        {
            "name": "7. Валидация: неверный канал и пустые получатели (422)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('422 Unprocessable', () => pm.response.to.have.status(422));",
                            "const errors = pm.response.json().errors;",
                            "pm.test('ошибки на channel и recipient_ids', () => { pm.expect(errors).to.have.property('channel'); pm.expect(errors).to.have.property('recipient_ids'); });"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    { "key": "Idempotency-Key", "value": "invalid-req-1" },
                    { "key": "Content-Type", "value": "application/json" },
                    { "key": "Accept", "value": "application/json" }
                ],
                "url": "{{base_url}}/notifications",
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"channel\": \"pigeon\",\n    \"text\": \"\",\n    \"recipient_ids\": []\n}"
                },
                "description": "Недопустимый канал и пустой список получателей — ожидается 422 с ошибками валидации по нескольким полям."
            }
        }
    ]
}